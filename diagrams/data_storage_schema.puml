@startuml
title Схема хранения данных

skinparam component {
    BackgroundColor<<service>> LightBlue
    BorderColor<<service>> DarkBlue
    ArrowColor<<service>> DarkBlue
}

skinparam rectangle {
    BackgroundColor<<entity>> LightGreen
    BorderColor<<entity>> DarkGreen
    ArrowColor<<entity>> DarkGreen
}

package "Хранилище данных" {
    [UserProfile] <<entity>>
    [Chat] <<entity>>
    [Message] <<entity>>
    [Attachment] <<entity>>
    [File] <<entity>>
    [FileMetadata] <<entity>>
    [ChatMember] <<entity>>
    
    [UserProfile] --> [Chat] : участвует
    [Chat] --> [Message] : содержит
    [Message] --> [Attachment] : имеет
    [Attachment] --> [File] : ссылается на
    [File] --> [FileMetadata] : имеет
    
    [Chat] --> [ChatMember] : участники
    [ChatMember] --> [UserProfile] : пользователь
}

note top of [UserProfile]
  UUID, externalId, username, email
  firstName, lastName, avatarUrl
  status, createdAt, updatedAt
end note

note top of [Chat]
  UUID, chatType, name, description
  createdBy, createdAt, lastMessageAt
  members, admins
end note

note top of [Message]
  UUID, chatId, senderId, content
  contentType, timestamp, edited
  editedAt, reactions, attachments
end note

note top of [Attachment]
  UUID, fileId, fileName, fileSize
  fileType, url, uploadedAt
end note

note top of [File]
  UUID, fileName, fileSize, fileType
  fileUrl, uploadedBy, uploadedAt
  storageLocation, isPublic
end note
@enduml