@startuml
title Архитектура сервиса обмена сообщениями

skinparam component {
    BackgroundColor<<service>> LightBlue
    BorderColor<<service>> DarkBlue
    ArrowColor<<service>> DarkBlue
}

skinparam rectangle {
    BackgroundColor<<entity>> LightGreen
    BorderColor<<entity>> DarkGreen
    ArrowColor<<entity>> DarkGreen
}

package "Сервис обмена сообщениями" {
    [UserProfile] <<entity>>
    [Message] <<entity>>
    [Chat] <<entity>>
    [Attachment] <<entity>>
    [File] <<entity>>
    [FileMetadata] <<entity>>
    
    [Messaging Service] <<service>>
    [Database] <<service>>
    [File Storage] <<service>>
    
    [Messaging Service] --> [Database]
    [Messaging Service] --> [File Storage]
    [Message] --> [Chat]
    [Message] --> [Attachment]
    [Attachment] --> [File]
    [File] --> [FileMetadata]
    [UserProfile] --> [Message]
    [UserProfile] --> [Chat]
}

note right of [Messaging Service]
  Сервис обработки
  сообщений
end note

note right of [Database]
  Хранит все
  сущности
end note

note right of [File Storage]
  Внешняя система
  хранения файлов
end note
@enduml